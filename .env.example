# Guardrails 環境變量範例文件
# 複製此文件為 .env.local 或 .env 並填入實際值

# ================================
# API Keys
# ================================

# Instreet API Key (用於社群數據獲取)
INSTREET_API_KEY=your_instreet_api_key_here

# OpenRouter API Key (用於模型路由)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Jina AI API Key (用於 Embedding 和 Rerank)
JINA_API_KEY=your_jina_api_key_here

# ================================
# Supabase
# ================================

# Supabase 項目 URL
SUPABASE_URL=your_supabase_url_here

# Supabase 匿名密鑰 (公開)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase 服務角色密鑰 (私有)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ================================
# GitHub
# ================================

# GitHub 個人訪問令牌 (用於倉庫操作)
GITHUB_TOKEN=your_github_token_here

# ================================
# Vercel
# ================================

# Vercel API 令牌 (用於部署操作)
VERCEL_API_TOKEN=your_vercel_api_token_here

# ================================
# 其他服務 (可選)
# ================================

# Coze 工作流 ID (如果使用 Coze)
COZE_WORKFLOW_ID=your_coze_workflow_id_here

# SCRAPERCREATORS API Key (如果使用)
SCRAPERCREATORS_API_KEY=your_scrapecreators_api_key_here

# ================================
# 注意事項
# ================================

1. 不要將包含真實密鑰的 .env 或 .env.local 文件提交到 Git
2. .env.example 只包含範例，可以安全提交
3. 在實際部署時，使用環境變量或密鑰管理服務
4. 定期輪換 API Keys 以提高安全性
